#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10,<3.13"
# dependencies = [
#   "faster-whisper>=1.1.0",
#   "yt-dlp>=2025.1.1",
#   "Pillow>=10.0",
#   "numpy>=1.24",
#   "pytesseract>=0.3.10",
# ]
# ///
"""
watch-video — turn a video (Loom / URL / local file) into something an LLM can read:
a timestamped transcript + a deduplicated set of key frames (+ optional OCR of
on-screen text). Built so a CLI coding agent (Claude Code, etc.) can "watch" a
client's screen-recording and decipher it.

Everything runs LOCALLY (yt-dlp + ffmpeg + faster-whisper + tesseract). No video or
audio is sent to a cloud service — important when the recording contains private /
financial data. The only thing that leaves your machine is whatever you (or your
agent) later choose to read out of the output folder.

Usage:
    watch-video <loom-url | any-url | local-file> [options]

Common options:
    --out DIR                 output folder (default: ./watch-video-out/<slug>)
    --model NAME              whisper model: tiny|base|small|medium|large-v3 (default: small)
    --periodic SECONDS        sample a frame every N seconds (default: 4)
    --scene-threshold FLOAT   extra frame on scene change, 0..1 (default: 0.08)
    --max-frames N            cap kept frames (default: 200)
    --dedupe-distance N       perceptual-hash hamming distance to treat frames as dupes (default: 6)
    --no-ocr                  skip the tesseract OCR pass
    --no-contact-sheet        skip the montage overview image
    --cookies-from-browser B  pass private/team Loom auth via browser cookies (firefox|chrome|...)
    --cookies FILE            pass a Netscape cookies.txt for yt-dlp
    --language LANG           force transcription language (e.g. en); default = auto-detect

Output folder contains: SUMMARY.md (read this first), transcript.md, transcript.txt,
frames/*.jpg, frames/ocr/*.txt (if OCR), contact-sheet.jpg.
"""

import argparse
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path
import json
from datetime import datetime, timezone, timedelta

WATCH_VIDEO_VERSION = "1.1.0"


def write_manifest(out_dir, source):
    """Write the hidden ownership marker every cleanup operation validates.
    Preserves an existing valid manifest's `created` so re-runs don't reset run age."""
    mf = out_dir / ".watch-video.json"
    created = None
    if mf.is_file():
        try:
            old = json.loads(mf.read_text())
            if old.get("tool") == "watch-video":
                created = old.get("created")
        except Exception:
            created = None
    manifest = {
        "tool": "watch-video",
        "version": WATCH_VIDEO_VERSION,
        "source": str(source),
        "created": created or datetime.now(timezone.utc).isoformat(),
    }
    mf.write_text(json.dumps(manifest, indent=2) + "\n")


def is_watch_video_dir(path):
    """True only if path holds a .watch-video.json whose SIGNATURE validates — not mere
    filename presence. The single ownership gate used by reconciliation AND cleanup."""
    mf = Path(path) / ".watch-video.json"
    if not mf.is_file():
        return False
    try:
        return json.loads(mf.read_text()).get("tool") == "watch-video"
    except Exception:
        return False


def eprint(*a):
    print(*a, file=sys.stderr, flush=True)


def run(cmd, **kw):
    return subprocess.run(cmd, check=True, **kw)


def have(binary):
    return shutil.which(binary) is not None


def slugify(text):
    text = re.sub(r"^https?://", "", text)
    text = re.sub(r"[^a-zA-Z0-9._-]+", "-", text).strip("-")
    return (text[:60] or "video").lower()


def hms(seconds):
    seconds = int(seconds)
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h:d}:{m:02d}:{s:02d}" if h else f"{m:d}:{s:02d}"


# ---------------------------------------------------------------------------
# 1. acquire the video (local file passthrough, else yt-dlp)
# ---------------------------------------------------------------------------
def acquire(source, out_dir, cookies_from_browser, cookies_file):
    local = Path(source).expanduser()
    if local.exists() and local.is_file():
        eprint(f"[acquire] local file: {local}")
        return local, False

    if not have("yt-dlp"):
        sys.exit("ERROR: yt-dlp not found. Install with: uv tool install yt-dlp")

    target = out_dir / "source.%(ext)s"
    cmd = [
        "yt-dlp",
        "--no-playlist",
        "-f", "bv*+ba/b",            # best video+audio, merged by ffmpeg
        "--merge-output-format", "mp4",
        "-o", str(target),
    ]
    if cookies_from_browser:
        cmd += ["--cookies-from-browser", cookies_from_browser]
    if cookies_file:
        cmd += ["--cookies", str(Path(cookies_file).expanduser())]
    cmd.append(source)
    eprint(f"[acquire] downloading via yt-dlp: {source}")
    run(cmd)
    mp4s = sorted(out_dir.glob("source.*"))
    if not mp4s:
        sys.exit("ERROR: yt-dlp produced no file (private link needs --cookies-from-browser?).")
    return mp4s[0], True


# ---------------------------------------------------------------------------
# 2. probe duration
# ---------------------------------------------------------------------------
def duration_seconds(video):
    try:
        out = subprocess.run(
            ["ffprobe", "-v", "error", "-show_entries", "format=duration",
             "-of", "default=nw=1:nk=1", str(video)],
            check=True, capture_output=True, text=True,
        ).stdout.strip()
        return float(out)
    except Exception:
        return 0.0


# ---------------------------------------------------------------------------
# 3. extract frames: first + periodic + scene-change, then perceptual dedupe
# ---------------------------------------------------------------------------
def extract_frames(video, frames_dir, periodic, scene_threshold):
    frames_dir.mkdir(parents=True, exist_ok=True)
    select = (
        f"select='eq(n\\,0)+gt(scene\\,{scene_threshold})+not(mod(t\\,{periodic}))',"
        "showinfo"
    )
    info_log = frames_dir / "_showinfo.txt"
    with open(info_log, "w") as log:
        subprocess.run(
            ["ffmpeg", "-hide_banner", "-loglevel", "info", "-i", str(video),
             "-vf", select, "-vsync", "vfr", "-q:v", "2",
             str(frames_dir / "%06d.jpg")],
            check=True, stderr=log,
        )
    # map each emitted frame (in order) to its pts_time from showinfo
    times = [float(m) for m in re.findall(r"pts_time:([0-9.]+)", info_log.read_text())]
    info_log.unlink(missing_ok=True)
    frames = sorted(frames_dir.glob("[0-9]*.jpg"))
    if len(times) != len(frames):
        eprint(f"[frames] WARNING: showinfo emitted {len(times)} timestamps for {len(frames)} frames; extra frames get t=0.0")
    return list(zip(frames, times + [0.0] * (len(frames) - len(times))))


def dhash(path, size=8):
    from PIL import Image
    import numpy as np
    img = Image.open(path).convert("L").resize((size + 1, size), Image.LANCZOS)
    arr = np.asarray(img, dtype=np.int16)
    diff = arr[:, 1:] > arr[:, :-1]
    bits = 0
    for b in diff.flatten():
        bits = (bits << 1) | int(b)
    return bits


def hamming(a, b):
    return bin(a ^ b).count("1")


def dedupe(frame_times, distance, max_frames):
    kept, last_hash = [], None
    for path, t in frame_times:
        h = dhash(path)
        if last_hash is not None and hamming(h, last_hash) < distance:
            path.unlink(missing_ok=True)      # drop near-duplicate
            continue
        kept.append((path, t))
        last_hash = h
    # enforce cap by uniform thinning (keep first/last, sample the middle)
    if len(kept) > max_frames:
        if max_frames <= 1:
            idx = [0]
        else:
            idx = sorted({round(i * (len(kept) - 1) / (max_frames - 1)) for i in range(max_frames)})
        keepset = {kept[i][0] for i in idx}
        for path, _ in kept:
            if path not in keepset:
                path.unlink(missing_ok=True)
        kept = [(p, t) for p, t in kept if p in keepset]
    # renumber kept frames sequentially with their timestamp baked into the name
    renamed = []
    for i, (path, t) in enumerate(kept):
        new = path.with_name(f"frame_{i:03d}_{hms(t).replace(':', 'm')}s.jpg")
        path.rename(new)
        renamed.append((new, t))
    return renamed


# ---------------------------------------------------------------------------
# 4. transcribe with faster-whisper (local, CPU int8 by default)
# ---------------------------------------------------------------------------
def transcribe(video, out_dir, model_name, language):
    from faster_whisper import WhisperModel
    eprint(f"[transcribe] loading whisper '{model_name}' (CPU/int8; first run downloads the model)…")
    model = WhisperModel(model_name, device="cpu", compute_type="int8")
    segments, info = model.transcribe(str(video), language=language, vad_filter=True)
    md, txt, segments_out = [], [], []
    for seg in segments:
        stamp = hms(seg.start)
        line = seg.text.strip()
        md.append(f"- **[{stamp}]** {line}")
        txt.append(line)
        segments_out.append((seg.start, line))
    (out_dir / "transcript.md").write_text(
        f"# Transcript ({model_name}, lang={info.language})\n\n" + "\n".join(md) + "\n"
    )
    (out_dir / "transcript.txt").write_text("\n".join(txt) + "\n")
    return info.language, segments_out


def _prep_for_ocr(img):
    """Upscale + grayscale + threshold a frame for sharper on-screen-text OCR."""
    from PIL import Image
    import numpy as np
    if img.width < 1000:
        scale = 1000 / img.width
        img = img.resize((int(img.width * scale), int(img.height * scale)), Image.LANCZOS)
    gray = np.asarray(img.convert("L"))
    thresh = gray.mean()
    bw = (gray > thresh).astype("uint8") * 255
    return Image.fromarray(bw)


# ---------------------------------------------------------------------------
# 5. OCR each kept frame (optional; financial numbers shown on screen)
# ---------------------------------------------------------------------------
def ocr_frames(frames, frames_dir, tuned=False):
    import pytesseract
    from PIL import Image
    ocr_dir = frames_dir / "ocr"
    ocr_dir.mkdir(exist_ok=True)
    combined = []
    ocr_map = {}
    for path, t in frames:
        im = Image.open(path)
        if tuned:
            im = _prep_for_ocr(im)
            text = pytesseract.image_to_string(im, config="--psm 6").strip()
        else:
            text = pytesseract.image_to_string(im).strip()
        ocr_map[path] = text
        (ocr_dir / (path.stem + ".txt")).write_text(text)
        if text:
            combined.append(f"### {path.name} (@ {hms(t)})\n{text}\n")
    (frames_dir / "ocr-combined.md").write_text("\n".join(combined) + "\n")
    return ocr_map


# ---------------------------------------------------------------------------
# 6. contact sheet montage (overview)
# ---------------------------------------------------------------------------
def contact_sheet(frames, out_path, cols=4, thumb_w=480):
    from PIL import Image, ImageDraw
    if not frames:
        return None
    thumbs = []
    for path, t in frames:
        im = Image.open(path).convert("RGB")
        ratio = thumb_w / im.width
        im = im.resize((thumb_w, int(im.height * ratio)))
        d = ImageDraw.Draw(im)
        label = hms(t)
        d.rectangle([0, 0, 8 + 8 * len(label), 18], fill=(0, 0, 0))
        d.text((4, 3), label, fill=(255, 255, 255))
        thumbs.append(im)
    rows = (len(thumbs) + cols - 1) // cols
    cell_h = max(t.height for t in thumbs)
    sheet = Image.new("RGB", (cols * thumb_w, rows * cell_h), (20, 20, 20))
    for i, im in enumerate(thumbs):
        sheet.paste(im, ((i % cols) * thumb_w, (i // cols) * cell_h))
    sheet.save(out_path, quality=85)
    return out_path


def write_timeline(out_dir, kept, segments, ocr_map):
    """Chronological merge of frames + transcript + OCR. Tolerates missing inputs."""
    lines = ["# Timeline\n"]
    n = len(kept)
    for i, (path, t) in enumerate(kept):
        next_t = kept[i + 1][1] if i + 1 < n else float("inf")
        lines.append(f"## {hms(t)}")
        lines.append(f"![frame](frames/{path.name})")
        for s, said in segments:
            if t <= s < next_t:
                lines.append(f"> {said}")
        snippet = " ".join((ocr_map.get(path, "") or "").split())[:200]
        if snippet:
            lines.append(f"OCR: {snippet}")
        lines.append("")
    (out_dir / "timeline.md").write_text("\n".join(lines) + "\n")


def reconcile_stale(out_dir, frames_dir, dir_was_ours, do_transcribe, do_timeline, do_contact):
    """Remove prior watch-video artifacts this run will NOT (re)produce, so SUMMARY stays accurate.
    Acts ONLY when the folder was already a watch-video output before this run (dir_was_ours) --
    so it never touches a user's pre-existing non-watch-video folder."""
    if not dir_was_ours:
        return
    if not do_transcribe:
        (out_dir / "transcript.md").unlink(missing_ok=True)
        (out_dir / "transcript.txt").unlink(missing_ok=True)
    if not do_timeline:
        (out_dir / "timeline.md").unlink(missing_ok=True)
    if not do_contact:
        (out_dir / "contact-sheet.jpg").unlink(missing_ok=True)
    # OCR outputs are stale every re-run (frames are re-extracted) -- always clear them; they are
    # regenerated this run if OCR runs. This also fixes lingering per-frame files when OCR stays on.
    (frames_dir / "ocr-combined.md").unlink(missing_ok=True)
    ocr_dir = frames_dir / "ocr"
    if ocr_dir.exists():
        for f in ocr_dir.glob("*.txt"):
            f.unlink(missing_ok=True)
    # frames are always re-extracted fresh -- clear watch-video's OWN frame-name patterns only
    # (extraction temps "NNNNNN.jpg" + deduped "frame_*.jpg"), never a user's unrelated .jpg.
    if frames_dir.exists():
        for pattern in ("frame_*.jpg", "[0-9][0-9][0-9][0-9][0-9][0-9].jpg"):
            for f in frames_dir.glob(pattern):
                f.unlink(missing_ok=True)


def manifest_created(path):
    try:
        data = json.loads((Path(path) / ".watch-video.json").read_text())
        return datetime.fromisoformat(data["created"])
    except Exception:
        return None


def _looks_like_path(arg):
    return ("/" in arg) or ("\\" in arg) or Path(arg).is_absolute()


# The exact set of files/dirs watch-video creates in an output folder.
WV_ARTIFACT_NAMES = ("SUMMARY.md", "transcript.md", "transcript.txt", "timeline.md",
                     "contact-sheet.jpg", ".watch-video.json")


def remove_wv_artifacts(d):
    """Delete ONLY watch-video's own artifacts in d, then rmdir d if it is now empty.
    Never blanket-deletes the folder: if the user pointed --out at a folder containing
    their own files, those survive and the folder is left in place."""
    d = Path(d)
    for name in WV_ARTIFACT_NAMES:
        (d / name).unlink(missing_ok=True)
    for s in d.glob("source.*"):       # the downloaded source video, if kept
        s.unlink(missing_ok=True)
    frames = d / "frames"
    if frames.exists():
        (frames / "ocr-combined.md").unlink(missing_ok=True)
        (frames / "_showinfo.txt").unlink(missing_ok=True)
        ocr_dir = frames / "ocr"
        if ocr_dir.exists():
            for f in ocr_dir.glob("*.txt"):
                f.unlink(missing_ok=True)
            try:
                ocr_dir.rmdir()
            except OSError:
                pass
        for pattern in ("frame_*.jpg", "[0-9][0-9][0-9][0-9][0-9][0-9].jpg"):
            for f in frames.glob(pattern):
                f.unlink(missing_ok=True)
        try:
            frames.rmdir()   # remove frames/ only if now empty — user's own files survive
        except OSError:
            pass
    try:
        d.rmdir()                      # removes the folder ONLY if nothing else remains
        return True
    except OSError:
        eprint(f"[clean] {d}: removed watch-video artifacts; folder kept (contains other files)")
        return False


def do_clean(clean_arg, older_than, base):
    targets, skipped = [], []
    if older_than is not None:
        cutoff = datetime.now(timezone.utc) - timedelta(days=older_than)
        if base.exists():
            for d in sorted(p for p in base.iterdir() if p.is_dir()):
                created = manifest_created(d)
                if is_watch_video_dir(d) and created is not None and created < cutoff:
                    targets.append(d)
                else:
                    skipped.append(d)
    elif clean_arg == "all":
        if base.exists():
            for d in sorted(p for p in base.iterdir() if p.is_dir()):
                (targets if is_watch_video_dir(d) else skipped).append(d)
    elif clean_arg and _looks_like_path(clean_arg):
        d = Path(clean_arg).expanduser()
        (targets if is_watch_video_dir(d) else skipped).append(d)
    elif clean_arg:  # bare token -> slug under base
        d = base / clean_arg
        (targets if is_watch_video_dir(d) else skipped).append(d)
    for d in targets:
        removed = remove_wv_artifacts(d)
        eprint(f"[clean] {'deleted' if removed else 'cleaned (folder kept)'} {d}")
    for d in skipped:
        eprint(f"[clean] skipped (no valid watch-video manifest) {d}")
    return targets, skipped


def prune_source(video, was_downloaded):
    """Delete the source video ONLY if watch-video downloaded it. Never deletes a
    user-provided local input. Returns True if it deleted something."""
    if not was_downloaded:
        return False
    try:
        Path(video).unlink(missing_ok=True)
        eprint(f"[no-source] removed downloaded source {video}")
        return True
    except Exception as e:
        eprint(f"[no-source] could not remove source: {e}")
        return False


# ---------------------------------------------------------------------------
def main():
    p = argparse.ArgumentParser(prog="watch-video", description="Video → transcript + key frames for an LLM.")
    p.add_argument("source", nargs="?", help="Loom/any URL, or a local video file")
    p.add_argument("--clean", metavar="SLUG|PATH|all",
                   help="janitorial: delete a watch-video output folder and exit")
    p.add_argument("--clean-older-than", type=int, metavar="DAYS",
                   help="janitorial: delete watch-video folders older than DAYS and exit")
    p.add_argument("--out")
    p.add_argument("--model", default="small")
    p.add_argument("--periodic", type=float, default=4)
    p.add_argument("--scene-threshold", type=float, default=0.08)
    p.add_argument("--max-frames", type=int, default=200)
    p.add_argument("--dedupe-distance", type=int, default=6)
    p.add_argument("--no-ocr", action="store_true")
    p.add_argument("--no-contact-sheet", action="store_true")
    p.add_argument("--no-timeline", action="store_true")
    p.add_argument("--no-source", action="store_true")
    p.add_argument("--ocr-tuned", action="store_true")
    p.add_argument("--cookies-from-browser")
    p.add_argument("--cookies")
    p.add_argument("--language")
    p.add_argument("--no-transcribe", action="store_true")
    args = p.parse_args()

    if args.clean is not None and args.clean_older_than is not None:
        p.error("--clean and --clean-older-than are mutually exclusive")
    if args.clean_older_than is not None and args.clean_older_than < 0:
        p.error("--clean-older-than DAYS must be >= 0")
    if args.clean is not None or args.clean_older_than is not None:
        base = Path.cwd() / "watch-video-out"
        do_clean(args.clean, args.clean_older_than, base)
        return
    if not args.source:
        p.error("source is required unless --clean/--clean-older-than is given")

    if not have("ffmpeg"):
        sys.exit("ERROR: ffmpeg not found (sudo dnf install ffmpeg).")

    out_dir = Path(args.out).expanduser() if args.out else Path.cwd() / "watch-video-out" / slugify(args.source)
    out_dir.mkdir(parents=True, exist_ok=True)
    frames_dir = out_dir / "frames"
    eprint(f"[watch-video] output → {out_dir}")
    dir_was_ours = is_watch_video_dir(out_dir)   # validates the manifest signature, not just presence
    write_manifest(out_dir, args.source)

    video, was_downloaded = acquire(args.source, out_dir, args.cookies_from_browser, args.cookies)
    dur = duration_seconds(video)

    do_transcribe = not args.no_transcribe
    do_timeline_planned = not args.no_timeline
    do_contact_planned = not args.no_contact_sheet
    frames_dir.mkdir(parents=True, exist_ok=True)
    reconcile_stale(out_dir, frames_dir, dir_was_ours, do_transcribe,
                    do_timeline_planned, do_contact_planned)

    eprint("[frames] extracting (first + scene-change + periodic)…")
    raw = extract_frames(video, frames_dir, args.periodic, args.scene_threshold)
    kept = dedupe(raw, args.dedupe_distance, args.max_frames)
    eprint(f"[frames] {len(raw)} extracted → {len(kept)} kept after dedupe")

    if args.no_transcribe:
        lang, segments = "skipped", []
        eprint("[transcribe] skipped (--no-transcribe)")
    else:
        lang, segments = transcribe(video, out_dir, args.model, args.language)
    n_seg = len(segments)

    do_ocr = (not args.no_ocr) and have("tesseract")
    if not args.no_ocr and not have("tesseract"):
        eprint("[ocr] tesseract not found — skipping OCR (sudo dnf install tesseract).")
    ocr_map = {}
    if do_ocr:
        eprint(f"[ocr] reading on-screen text from {len(kept)} frames…")
        ocr_map = ocr_frames(kept, frames_dir, tuned=args.ocr_tuned)

    sheet = None
    if not args.no_contact_sheet:
        sheet = contact_sheet(kept, out_dir / "contact-sheet.jpg")

    do_timeline = not args.no_timeline
    if do_timeline:
        write_timeline(out_dir, kept, segments, ocr_map)

    # SUMMARY.md — the entry point an agent reads first
    lines = [
        f"# watch-video result — {slugify(args.source)}",
        "",
        f"- **Source:** `{args.source}`",
        f"- **Duration:** {hms(dur)}",
        f"- **Frames kept:** {len(kept)} (deduped from {len(raw)})",
        f"- **Transcript:** {n_seg} segments, language `{lang}`",
        f"- **OCR:** {'yes → frames/ocr-combined.md' if do_ocr else 'no'}",
        f"- **Contact sheet:** {'contact-sheet.jpg' if sheet else 'none'}",
        f"- **Timeline:** {'yes → timeline.md' if do_timeline else 'no'}",
        "",
        "## How to read this (for an LLM/agent)",
        "0. Read this SUMMARY, then read the files it lists below (skip any not present).",
        "1. `timeline.md` interleaves each frame with what was said + on-screen text — read this first.",
        "2. `transcript.md` for the full timestamped transcript.",
        "3. Open individual `frames/*.jpg`; cross-check exact numbers against `frames/ocr-combined.md`"
        " (OCR can misread; the image is ground truth).",
        "",
        "> ⚠️ This folder may contain private/financial client data — do not commit it.",
        "",
        "## Frames",
    ]
    for path, t in kept:
        lines.append(f"- `frames/{path.name}` @ {hms(t)}")
    (out_dir / "SUMMARY.md").write_text("\n".join(lines) + "\n")

    if args.no_source:
        prune_source(video, was_downloaded)

    eprint(f"\n[done] {out_dir}/SUMMARY.md")
    print(str(out_dir / "SUMMARY.md"))


if __name__ == "__main__":
    main()
